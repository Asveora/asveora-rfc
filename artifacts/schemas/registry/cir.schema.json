{
  "$schema": "https://json-schema.org/draft/2020-12/schema",

  "$id": "https://cdn.asveora.social/schemas/v1/cir.schema.json",

  "title": "Canonical Identity Record (CIR)",
  "type": "object",

  "additionalProperties": false,

  "required": [
    "pik",
    "apa",
    "vsig",
    "identity_state",
    "instance_origin",
    "created_at",
    "last_updated"
  ],

  "properties": {

    "pik": {
      "type": "string",
      "description": "Primary Identity Key - immutable identity anchor within a Network Instance",
      "pattern": "^[a-f0-9]{8,64}$"
    },

    "apa": {
      "type": "string",
      "description": "Asveora Profile Address - resolvable identity locator",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[a-zA-Z0-9._-]+\\.[a-zA-Z0-9._-]+$"
    },

    "vsig": {
      "type": "string",
      "description": "Verification Signature issued by the authoritative Network Instance",
      "pattern": "^VSIG-[a-f0-9]{8,64}$"
    },

    "rgbsig": {
      "type": "string",
      "description": "Optional presentation-layer visual identity signature (NOT used in validation)",
      "pattern": "^[0-9]{3}[0-9]{3}[0-9]{3}-[0-9]{3}[0-9]{3}[0-9]{3}-[0-9]{3}[0-9]{3}[0-9]{3}$"
    },

    "identity_state": {
      "type": "string",
      "description": "Deterministic lifecycle state of the identity",
      "enum": [
        "INITIATED",
        "VERIFIED",
        "VALIDATED",
        "ACTIVE",
        "SUSPENDED",
        "MIGRATING",
        "TOMBSTONED"
      ]
    },

    "instance_origin": {
      "type": "string",
      "description": "Origin Network Instance that issued the CIR",
      "minLength": 3,
      "maxLength": 256
    },

    "created_at": {
      "type": "string",
      "description": "ISO-8601 timestamp of CIR creation",
      "format": "date-time"
    },

    "last_updated": {
      "type": "string",
      "description": "ISO-8601 timestamp of last CIR mutation (logically append-only)",
      "format": "date-time"
    },

    "lifecycle_metadata": {
      "type": "object",
      "description": "Optional governance and lifecycle tracking metadata (non-authoritative)",
      "additionalProperties": true,
      "properties": {
        "migration_source": { "type": "string" },
        "migration_target": { "type": "string" },
        "suspension_reason": { "type": "string" },
        "tombstone_reason": { "type": "string" }
      }
    },

    "federation_metadata": {
      "type": "object",
      "description": "Non-authoritative federation context data",
      "additionalProperties": true,
      "properties": {
        "last_synced_instance": { "type": "string" },

        "sync_state": {
          "type": "string",
          "enum": [
            "SYNCED",
            "STALE",
            "QUARANTINED",
            "DEGRADED"
          ]
        },

        "trust_hint": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  },

  "allOf": [
    {
      "if": {
        "properties": {
          "identity_state": { "const": "TOMBSTONED" }
        }
      },
      "then": {
        "required": ["last_updated"]
      }
    }
  ]
}