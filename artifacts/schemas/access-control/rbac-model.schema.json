{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdn.asveora.social/schemas/access-control/rbac-model.schema.json",
  "title": "RBAC Model",
  "type": "object",
  "additionalProperties": false,

  "required": ["role_id", "role_name", "permissions", "created_at"],

  "properties": {

    "role_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{8,64}$"
    },

    "role_name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    },

    "description": {
      "type": "string",
      "maxLength": 512
    },

    "permissions": {
      "type": "array",
      "items": {
        "$ref": "./permission-scopes.schema.json"
      }
    },

    "inherits": {
      "type": "array",
      "description": "Role inheritance chain. Inheritance MUST NOT grant privileges outside RBAC-defined permissions and MUST NOT affect registry, identity, or exposure decisions.",
      "items": {
        "type": "string",
        "pattern": "^[a-f0-9]{8,64}$"
      }
    },

    "created_at": {
      "type": "string",
      "format": "date-time"
    },

    "metadata": {
      "type": "object",
	  "description": "Non-authoritative auxiliary data. MUST NOT influence authorization, registry state, identity resolution, or exposure decisions.",
      "additionalProperties": false
    }
  }
}